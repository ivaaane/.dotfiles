include ~/.config/newsboat/dark

auto-reload yes
max-items 100

highlight feedlist "\\(Youtube\\) .*" red
highlight feedlist "\\(Reddit\\) .*" green
highlight feedlist "\\(Podcast\\) .*" magenta
highlight feedlist "\\(Blog\\) .*" yellow

browser firefox
macro m set browser "mpv %u"; open-in-browser ; set browser "firefox %u"
