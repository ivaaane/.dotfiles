{
  "$schema": "https://github.com/fastfetch-cli/fastfetch/raw/dev/doc/json_schema.json",
  "logo": {
      "type": "small",
      "padding": {
          "top": 2,
          "left": 3
      }
  },
  "display": {
      "separator": " > "
  },
  "modules": [
    "title",
    "os",
    "kernel",
    "shell",
    "terminal",
    "de",
    "wm",
    "packages",
    {
        "type": "command",
        "key": "Languages",
        "text": "projfetch -u 10 -se C++ -e HTML -e CSS -e Makefile ~/code"
    },
    "host",
    "disk",
    "cpu",
    "localip",
    "uptime"
  ]
}
